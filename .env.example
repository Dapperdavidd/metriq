# Metriq environment. Copy to .env and fill in. NEVER commit .env.
# The operator key signs every charge. Use a throwaway testnet key only.

# On-chain
OPERATOR_KEY=0xyour_throwaway_testnet_private_key
RPC_URL=https://testrpc.xlayer.tech
TREASURY_ADDRESS=0xyour_treasury_address
TALLO_ADDRESS=
TASK_ROUTER_ADDRESS=

# X Layer testnet explorer base (used for Stub serial links)
EXPLORER_BASE=https://www.oklink.com/xlayer-test

# AI layer (Copilot). ALL OPTIONAL: the deterministic fallback runs with none of these,
# fully offline and free. Set one path only if you want a live LLM narrator.
#
# Path A (on-theme, paid): Claude via Anthropic. Costs cents per demo.
ANTHROPIC_API_KEY=
#
# Path B ($0): any OpenAI-compatible endpoint. Set COPILOT_BASE_URL and the swap is done.
#   Groq (free key, no card):        COPILOT_BASE_URL=https://api.groq.com/openai/v1
#                                     COPILOT_MODEL=llama-3.3-70b-versatile
#   Google AI Studio (free key):     COPILOT_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
#                                     COPILOT_MODEL=gemini-2.0-flash
#   Ollama (local, no key, offline): COPILOT_BASE_URL=http://localhost:11434/v1
#                                     COPILOT_MODEL=llama3.2
COPILOT_BASE_URL=
COPILOT_API_KEY=
COPILOT_MODEL=

# Host base URL the orchestrator posts subtask work to
HOST_BASE=http://localhost:3001
